@model AssignRolesViewModel
@{
    ViewData["Title"] = "Назначение ролей";
    var allRoles = ViewBag.AllRoles as IEnumerable<JwtAuthDemo.Models.Entities.Role>;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4"><i class="bi bi-person-badge"></i> Роли для @Model.UserName</h2>

        <div class="card">
            <div class="card-body">
                <form asp-action="AssignRoles" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="UserName" />

                    @if (allRoles != null)
                    {
                        @foreach (var role in allRoles)
                        {
                            <div class="form-check mb-2">
                                <input type="checkbox" name="SelectedRoleIds" value="@role.Id"
                                       class="form-check-input"
                                       id="role_@role.Id"
                                       checked="@(Model.SelectedRoleIds.Contains(role.Id))" />
                                <label for="role_@role.Id" class="form-check-label">
                                    <strong>@role.Name</strong>
                                    <small class="text-muted"> — @role.Description</small>
                                </label>
                            </div>
                        }
                    }

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> Сохранить
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
