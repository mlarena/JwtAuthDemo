@model AssignRolesViewModel
@{
    ViewData["Title"] = "Назначение ролей";
    var allRoles = ViewBag.AllRoles as IEnumerable<JwtAuthDemo.Models.Entities.Role>;
}

<div class="page-header">
    <h2><i class="fas fa-id-badge"></i> Роли для @Model.UserName</h2>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="AssignRoles" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="UserName" />

            @if (allRoles != null)
            {
                @foreach (var role in allRoles)
                {
                    <div class="form-check">
                        <input type="checkbox" name="SelectedRoleIds" value="@role.Id"
                               class="form-check-input"
                               id="role_@role.Id"
                               checked="@(Model.SelectedRoleIds.Contains(role.Id))" />
                        <label for="role_@role.Id" class="form-check-label">
                            <strong>@role.Name</strong>
                            <small> — @role.Description</small>
                        </label>
                    </div>
                }
            }
        </form>
    </div>
    <div class="card-footer">
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-check"></i> Сохранить
        </button>
        <a asp-action="Index" class="btn btn-secondary">Отмена</a>
    </div>
</div>
