@model JwtAuthDemo.Models.Entities.User
@{
    ViewData["Title"] = "Профиль";
    var auditLogs = ViewBag.AuditLogs as IEnumerable<JwtAuthDemo.Models.Entities.AuditLog>;
    var sessions = ViewBag.Sessions as IEnumerable<JwtAuthDemo.Models.Entities.RefreshToken>;
}

<div class="page-header">
    <h2><i class="fas fa-user-circle"></i> Профиль</h2>
    <div class="page-actions">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">
            <i class="fas fa-pencil-alt"></i> Редактировать
        </a>
    </div>
</div>

<div class="content-grid cols-2">
    <div>
        <div class="card">
            <div class="card-header"><i class="fas fa-user"></i> Личная информация</div>
            <div class="card-body">
                <dl class="detail-list">
                    <dt>Имя пользователя</dt>
                    <dd>@Model.UserName</dd>
                    <dt>Email</dt>
                    <dd>
                        @Model.Email
                        @if (Model.IsEmailConfirmed)
                        {
                            <span class="badge-success"><i class="fas fa-check"></i> Подтвержден</span>
                        }
                        else
                        {
                            <span class="badge-gray">Не подтвержден</span>
                        }
                    </dd>
                    <dt>Имя</dt>
                    <dd>@(Model.FirstName ?? "—")</dd>
                    <dt>Фамилия</dt>
                    <dd>@(Model.LastName ?? "—")</dd>
                    <dt>Роли</dt>
                    <dd>
                        @foreach (var ur in Model.UserRoles)
                        {
                            <span class="badge-success">@ur.Role.Name</span>
                        }
                    </dd>
                    <dt>Статус</dt>
                    <dd>
                        @if (Model.IsLocked)
                        {
                            <span class="badge-danger">Заблокирован</span>
                        }
                        else if (!Model.IsActive)
                        {
                            <span class="badge-gray">Неактивен</span>
                        }
                        else
                        {
                            <span class="badge-success">Активен</span>
                        }
                    </dd>
                    <dt>Регистрация</dt>
                    <dd>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><i class="fas fa-history"></i> Активные сессии</div>
            <div class="card-body">
                @if (sessions != null && sessions.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-striped">
                            <thead>
                                <tr>
                                    <th>Создана</th>
                                    <th>Истекает</th>
                                    <th>IP</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var session in sessions)
                                {
                                    <tr>
                                        <td>@session.Created.ToString("dd.MM HH:mm")</td>
                                        <td>@session.Expires.ToString("dd.MM HH:mm")</td>
                                        <td>@session.CreatedByIp</td>
                                        <td>
                                            <span class="badge-success">Активна</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p>Нет активных сессий</p>
                }
            </div>
        </div>
    </div>

    <div>
        <div class="card">
            <div class="card-header"><i class="fas fa-file-alt"></i> История входов</div>
            <div class="card-body">
                @if (auditLogs != null && auditLogs.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-striped">
                            <thead>
                                <tr>
                                    <th>Действие</th>
                                    <th>Дата</th>
                                    <th>Статус</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in auditLogs)
                                {
                                    <tr>
                                        <td>@log.Action</td>
                                        <td>@log.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>
                                            <span class="@(log.Status == "Success" ? "badge-success" : "badge-danger")">
                                                @log.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p>Нет записей</p>
                }
            </div>
        </div>
    </div>
</div>
