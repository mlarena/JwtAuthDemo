@model JwtAuthDemo.Models.Entities.User
@{
    ViewData["Title"] = "Детали пользователя";
}

<div class="page-header">
    <h2><i class="fas fa-user"></i> @Model.UserName</h2>
    <div class="page-actions">
        <a asp-action="AssignRoles" asp-route-id="@Model.Id" class="btn btn-outline-primary">
            <i class="fas fa-id-badge"></i> Роли
        </a>
        <a asp-action="Index" class="btn btn-secondary">Назад</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <dl class="detail-list">
            <dt>ID</dt>
            <dd>@Model.Id</dd>
            <dt>Имя пользователя</dt>
            <dd>@Model.UserName</dd>
            <dt>Email</dt>
            <dd>@Model.Email</dd>
            <dt>Имя</dt>
            <dd>@(Model.FirstName ?? "—")</dd>
            <dt>Фамилия</dt>
            <dd>@(Model.LastName ?? "—")</dd>
            <dt>Email подтвержден</dt>
            <dd>@(Model.IsEmailConfirmed ? "Да" : "Нет")</dd>
            <dt>Активен</dt>
            <dd>@(Model.IsActive ? "Да" : "Нет")</dd>
            <dt>Заблокирован</dt>
            <dd>@(Model.IsLocked ? "Да" : "Нет")</dd>
            <dt>Регистрация</dt>
            <dd>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
            <dt>Последний вход</dt>
            <dd>@(Model.LastLoginAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</dd>
        </dl>
    </div>
</div>

<div class="card">
    <div class="card-header">Роли</div>
    <div class="card-body">
        @foreach (var ur in Model.UserRoles)
        {
            <span class="badge-success">@ur.Role.Name</span>
        }
        @if (!Model.UserRoles.Any())
        {
            <span>Нет ролей</span>
        }
    </div>
</div>
