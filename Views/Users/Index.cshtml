@model IEnumerable<JwtAuthDemo.Models.Entities.User>
@{
    ViewData["Title"] = "Пользователи";
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
    var search = ViewBag.Search as string;
    var roleFilter = ViewBag.RoleFilter as string;
    var statusFilter = ViewBag.StatusFilter as string;
    var roles = ViewBag.Roles as IEnumerable<JwtAuthDemo.Models.Entities.Role>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people"></i> Пользователи</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Создать
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-3">
                <input type="text" name="search" value="@search" class="form-control" placeholder="Поиск..." />
            </div>
            <div class="col-md-3">
                <select name="role" class="form-select">
                    <option value="">Все роли</option>
                    @if (roles != null)
                    {
                        @foreach (var role in roles)
                        {
                            <option value="@role.Name" selected="@(roleFilter == role.Name)">@role.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select name="status" class="form-select">
                    <option value="">Все статусы</option>
                    <option value="active" selected="@(statusFilter == "active")">Активные</option>
                    <option value="inactive" selected="@(statusFilter == "inactive")">Неактивные</option>
                    <option value="locked" selected="@(statusFilter == "locked")">Заблокированные</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-outline-primary w-100">
                    <i class="bi bi-search"></i> Найти
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Имя</th>
                        <th>Email</th>
                        <th>Роли</th>
                        <th>Статус</th>
                        <th>Последний вход</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <strong>@user.UserName</strong>
                                @if (!string.IsNullOrEmpty(user.FirstName) || !string.IsNullOrEmpty(user.LastName))
                                {
                                    <br /><small class="text-muted">@user.FirstName @user.LastName</small>
                                }
                            </td>
                            <td>@user.Email</td>
                            <td>
                                @foreach (var ur in user.UserRoles)
                                {
                                    <span class="badge bg-secondary me-1">@ur.Role.Name</span>
                                }
                            </td>
                            <td>
                                @if (user.IsLocked)
                                {
                                    <span class="badge bg-danger">Заблокирован</span>
                                }
                                else if (!user.IsActive)
                                {
                                    <span class="badge bg-warning">Неактивен</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Активен</span>
                                }
                            </td>
                            <td>@(user.LastLoginAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-outline-info" title="Детали">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="AssignRoles" asp-route-id="@user.Id" class="btn btn-outline-warning" title="Роли">
                                        <i class="bi bi-person-badge"></i>
                                    </a>
                                    <form asp-action="ToggleLock" asp-route-id="@user.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-@(user.IsLocked ? "success" : "warning")" title="@(user.IsLocked ? "Разблокировать" : "Заблокировать")">
                                            <i class="bi bi-@(user.IsLocked ? "unlock" : "lock")"></i>
                                        </button>
                                    </form>
                                    <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Удалить пользователя?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger" title="Удалить">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@search"
                       asp-route-role="@roleFilter"
                       asp-route-status="@statusFilter">@i</a>
                </li>
            }
        </ul>
    </nav>
}
