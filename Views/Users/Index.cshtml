@model IEnumerable<JwtAuthDemo.Models.Entities.User>
@{
    ViewData["Title"] = "Пользователи";
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
    var search = ViewBag.Search as string;
    var roleFilter = ViewBag.RoleFilter as string;
    var statusFilter = ViewBag.StatusFilter as string;
    var roles = ViewBag.Roles as IEnumerable<JwtAuthDemo.Models.Entities.Role>;
}

<div class="page-header">
    <h2><i class="fas fa-users"></i> Пользователи</h2>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Создать
        </a>
    </div>
</div>

<div class="page-filters">
    <form asp-action="Index" method="get">
        <div class="form-row">
            <div class="form-group">
                <input type="text" name="search" value="@search" class="form-control" placeholder="Поиск..." />
            </div>
            <div class="form-group">
                <select name="role" class="form-control">
                    <option value="">Все роли</option>
                    @if (roles != null)
                    {
                        @foreach (var role in roles)
                        {
                            <option value="@role.Name" selected="@(roleFilter == role.Name)">@role.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <select name="status" class="form-control">
                    <option value="">Все статусы</option>
                    <option value="active" selected="@(statusFilter == "active")">Активные</option>
                    <option value="inactive" selected="@(statusFilter == "inactive")">Неактивные</option>
                    <option value="locked" selected="@(statusFilter == "locked")">Заблокированные</option>
                </select>
            </div>
            <div class="form-group">
                <button type="submit" class="btn btn-outline-primary">
                    <i class="fas fa-search"></i> Найти
                </button>
            </div>
        </div>
    </form>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead>
                    <tr>
                        <th>Имя</th>
                        <th>Email</th>
                        <th>Роли</th>
                        <th>Статус</th>
                        <th>Последний вход</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <strong>@user.UserName</strong>
                                @if (!string.IsNullOrEmpty(user.FirstName) || !string.IsNullOrEmpty(user.LastName))
                                {
                                    <br /><small>@user.FirstName @user.LastName</small>
                                }
                            </td>
                            <td>@user.Email</td>
                            <td>
                                @foreach (var ur in user.UserRoles)
                                {
                                    <span class="badge-gray">@ur.Role.Name</span>
                                }
                            </td>
                            <td>
                                @if (user.IsLocked)
                                {
                                    <span class="badge-danger">Заблокирован</span>
                                }
                                else if (!user.IsActive)
                                {
                                    <span class="badge-gray">Неактивен</span>
                                }
                                else
                                {
                                    <span class="badge-success">Активен</span>
                                }
                            </td>
                            <td>@(user.LastLoginAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
                            <td class="text-end">
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-icon btn-sm btn-outline-primary" title="Детали">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="AssignRoles" asp-route-id="@user.Id" class="btn btn-icon btn-sm btn-outline-primary" title="Роли">
                                        <i class="fas fa-id-badge"></i>
                                    </a>
                                    <form asp-action="ToggleLock" asp-route-id="@user.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-icon btn-sm @(user.IsLocked ? "btn-outline-primary" : "btn-outline-danger")" title="@(user.IsLocked ? "Разблокировать" : "Заблокировать")">
                                            <i class="fas fa-@(user.IsLocked ? "unlock" : "lock")"></i>
                                        </button>
                                    </form>
                                    <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Удалить пользователя?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-icon btn-sm btn-outline-danger" title="Удалить">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (totalPages > 1)
{
    <div class="pagination">
        @for (int i = 1; i <= totalPages; i++)
        {
            <a asp-action="Index"
               asp-route-page="@i"
               asp-route-search="@search"
               asp-route-role="@roleFilter"
               asp-route-status="@statusFilter"
               class="btn btn-sm @(i == currentPage ? "btn-primary" : "btn-secondary")">@i</a>
        }
    </div>
}
