@{
    ViewData["Title"] = "Подтверждение email";
}

<div class="auth-page">
    <div class="card">
        <div class="card-body auth-success">
            <div class="auth-success-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <h3>Email подтвержден</h3>
            <p class="auth-subtitle">Ваш email успешно подтвержден. Теперь вы можете войти в систему.</p>
            <a asp-action="Login" class="btn btn-primary">Войти</a>
        </div>
    </div>
</div>
