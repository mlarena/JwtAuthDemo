@model LoginViewModel
@{
    ViewData["Title"] = "Вход";
}

<div class="auth-page">
    <div class="card">
        <div class="card-body">
            <h3 class="auth-title"><i class="fas fa-sign-in-alt"></i> Вход</h3>

            <div asp-validation-summary="All" class="alert alert-danger"></div>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                <div class="form-group">
                    <label asp-for="UserNameOrEmail" class="form-label">Имя пользователя или Email</label>
                    <input asp-for="UserNameOrEmail" class="form-control" placeholder="Введите имя пользователя или email" />
                    <span asp-validation-for="UserNameOrEmail" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label">Пароль</label>
                    <div class="input-group">
                        <input asp-for="Password" class="form-control" placeholder="Введите пароль" />
                        <button class="btn btn-secondary password-toggle" type="button">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="form-error"></span>
                </div>

                <div class="form-group">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">Запомнить меня</label>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-full">Войти</button>
            </form>

            <div class="auth-links">
                <a asp-action="ForgotPassword">Забыли пароль?</a>
                <span class="auth-links-sep">|</span>
                <a asp-action="Register">Регистрация</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
