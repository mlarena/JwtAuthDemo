@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Новый пароль";
}

<div class="auth-page">
    <div class="card">
        <div class="card-body">
            <h3 class="auth-title"><i class="fas fa-key"></i> Новый пароль</h3>

            <div asp-validation-summary="All" class="alert alert-danger"></div>

            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Token" />

                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="NewPassword" class="form-label">Новый пароль</label>
                    <div class="input-group">
                        <input asp-for="NewPassword" class="form-control" />
                        <button class="btn btn-secondary password-toggle" type="button">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="NewPassword" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword" class="form-label">Подтверждение пароля</label>
                    <div class="input-group">
                        <input asp-for="ConfirmPassword" class="form-control" />
                        <button class="btn btn-secondary password-toggle" type="button">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="form-error"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-full">Сбросить пароль</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
