@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Сброс пароля";
}

<div class="auth-page">
    <div class="card">
        <div class="card-body">
            <h3 class="auth-title"><i class="fas fa-key"></i> Сброс пароля</h3>

            <p class="auth-subtitle">Введите email для получения инструкций по сбросу пароля</p>

            <div asp-validation-summary="All" class="alert alert-danger"></div>

            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" type="email" placeholder="Введите ваш email" />
                    <span asp-validation-for="Email" class="form-error"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-full">Отправить</button>
            </form>

            <div class="auth-links">
                <a asp-action="Login">Вернуться к входу</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
