@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Сброс пароля";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body p-4">
                <h3 class="card-title text-center mb-4"><i class="bi bi-key"></i> Сброс пароля</h3>

                <p class="text-muted text-center">Введите email для получения инструкций по сбросу пароля</p>

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <form asp-action="ForgotPassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="Введите ваш email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 mb-3">Отправить</button>
                </form>

                <div class="text-center">
                    <a asp-action="Login" class="text-decoration-none">Вернуться к входу</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
