@model ManagePermissionsViewModel
@{
    ViewData["Title"] = $"Права — {Model.RoleName}";
}

<div class="page-header">
    <h2><i class="fas fa-shield-alt"></i> Права: @Model.RoleName</h2>
    <div class="page-actions">
        <a asp-action="Index" class="btn btn-secondary">Назад</a>
    </div>
</div>

<form asp-action="ManagePermissions" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="RoleId" />
    <input type="hidden" asp-for="RoleName" />

    @foreach (var group in Model.PermissionGroups)
    {
        <div class="card mb-3">
            <div class="card-header">
                <div class="form-check">
                    <input type="checkbox" class="form-check-input group-toggle" id="group_@group.Resource"
                           data-resource="@group.Resource" />
                    <label for="group_@group.Resource" class="form-check-label">
                        <i class="fas fa-folder"></i> @group.Resource
                    </label>
                </div>
            </div>
            <div class="card-body">
                <div class="content-grid">
                    @foreach (var perm in group.Permissions)
                    {
                        <div class="form-check">
                            <input type="checkbox" name="SelectedPermissionIds" value="@perm.Id"
                                   class="form-check-input permission-check"
                                   data-resource="@group.Resource"
                                   id="perm_@perm.Id"
                                   checked="@(Model.SelectedPermissionIds.Contains(perm.Id))" />
                            <label for="perm_@perm.Id" class="form-check-label">
                                @perm.Name
                                <small class="text-muted d-block">@perm.Description</small>
                            </label>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <button type="submit" class="btn btn-primary">
        <i class="fas fa-check"></i> Сохранить разрешения
    </button>
</form>

@section Scripts {
    <script>
        document.querySelectorAll('.group-toggle').forEach(function (toggle) {
            toggle.addEventListener('change', function () {
                var resource = this.dataset.resource;
                var checked = this.checked;
                document.querySelectorAll('.permission-check[data-resource="' + resource + '"]')
                    .forEach(function (cb) { cb.checked = checked; });
            });
        });

        document.querySelectorAll('.permission-check').forEach(function (cb) {
            cb.addEventListener('change', function () {
                var resource = this.dataset.resource;
                var all = document.querySelectorAll('.permission-check[data-resource="' + resource + '"]');
                var checked = document.querySelectorAll('.permission-check[data-resource="' + resource + '"]:checked');
                var groupToggle = document.getElementById('group_' + resource);
                if (groupToggle) {
                    groupToggle.checked = all.length === checked.length;
                    groupToggle.indeterminate = checked.length > 0 && checked.length < all.length;
                }
            });
        });
    </script>
}
