@model IEnumerable<RoleViewModel>
@{
    ViewData["Title"] = "Роли";
}

<div class="page-header">
    <h2><i class="fas fa-user-shield"></i> Роли</h2>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Создать
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Описание</th>
                        <th>Системная</th>
                        <th>Пользователей</th>
                        <th>Разрешений</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in Model)
                    {
                        <tr>
                            <td><strong>@role.Name</strong></td>
                            <td>@role.Description</td>
                            <td>
                                @if (role.IsSystem)
                                {
                                    <span class="badge-gray">Системная</span>
                                }
                            </td>
                            <td>@role.UserCount</td>
                            <td>@role.PermissionCount</td>
                            <td>
                                <div class="table-actions">
                                    <a asp-action="ManagePermissions" asp-route-id="@role.Id" class="btn btn-icon btn-sm" title="Права">
                                        <i class="fas fa-shield-alt"></i>
                                    </a>
                                    @if (!role.IsSystem)
                                    {
                                        <a asp-action="Edit" asp-route-id="@role.Id" class="btn btn-icon btn-sm" title="Редактировать">
                                            <i class="fas fa-pencil-alt"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@role.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('Удалить роль?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-icon btn-sm btn-outline-danger" title="Удалить">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
