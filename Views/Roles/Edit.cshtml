@model CreateRoleViewModel
@{
    ViewData["Title"] = "Редактирование роли";
}

<div class="page-header">
    <h2><i class="fas fa-pencil-alt"></i> Редактирование роли</h2>
</div>

<div class="card">
    <div class="card-body">
        <div asp-validation-summary="All" class="alert alert-danger"></div>

        <form asp-action="Edit" asp-route-id="@ViewBag.RoleId" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Name" class="form-label">Название *</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="alert-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description" class="form-label">Описание</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="alert-danger"></span>
            </div>
        </form>
    </div>
    <div class="card-footer">
        <button type="submit" class="btn btn-primary" formmethod="post">
            <i class="fas fa-check"></i> Сохранить
        </button>
        <a asp-action="Index" class="btn btn-secondary">Отмена</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
