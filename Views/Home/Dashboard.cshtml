@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <h2><i class="fas fa-tachometer-alt"></i> Dashboard</h2>
    <p>Добро пожаловать, @User.Identity?.Name!</p>
</div>

<div class="content-grid cols-4">
    <div class="stat-card">
        <div class="card-body text-center">
            <i class="fas fa-users fa-2x"></i>
            <h3>@Model.TotalUsers</h3>
            <p>Всего пользователей</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="card-body text-center">
            <i class="fas fa-user-check fa-2x"></i>
            <h3>@Model.ActiveToday</h3>
            <p>Активных сегодня</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="card-body text-center">
            <i class="fas fa-user-plus fa-2x"></i>
            <h3>@Model.NewThisWeek</h3>
            <p>Новых за неделю</p>
        </div>
    </div>
    <div class="stat-card">
        <div class="card-body text-center">
            <i class="fas fa-wifi fa-2x"></i>
            <h3>@Model.OnlineNow</h3>
            <p>Онлайн сейчас</p>
        </div>
    </div>
</div>

<div class="content-grid cols-2">
    <div class="card">
        <div class="card-header">
            <i class="fas fa-activity"></i> Последние действия
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-striped">
                    <thead>
                        <tr>
                            <th>Пользователь</th>
                            <th>Действие</th>
                            <th>Статус</th>
                            <th>Дата</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.RecentActivity)
                        {
                            <tr>
                                <td>@log.UserName</td>
                                <td>@log.Action</td>
                                <td>
                                    <span class="@(log.Status == "Success" ? "badge-success" : "badge-danger")">
                                        @log.Status
                                    </span>
                                </td>
                                <td>@log.CreatedAt.ToString("dd.MM HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <i class="fas fa-chart-pie"></i> Распределение по ролям
        </div>
        <div class="card-body">
            @foreach (var role in Model.RoleDistribution)
            {
                var percentage = Model.TotalUsers > 0 ? (role.Count * 100.0 / Model.TotalUsers) : 0;
                <div class="form-group">
                    <div class="form-row">
                        <span>@role.RoleName</span>
                        <span>@role.Count (@percentage.ToString("F1")%)</span>
                    </div>
                    <div class="progress" style="height: 20px;">
                        <div class="progress-bar" style="width: @percentage%"></div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
