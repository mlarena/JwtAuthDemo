@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <h1>Dashboard</h1>
    <span class="text-secondary text-sm">Добро пожаловать, @User.Identity?.Name</span>
</div>

<div class="content-grid cols-4 mb-6">
    <div class="stat-card">
        <div class="stat-icon primary"><i class="fas fa-users"></i></div>
        <div class="stat-label">Всего пользователей</div>
        <div class="stat-value">@Model.TotalUsers</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon success"><i class="fas fa-user-check"></i></div>
        <div class="stat-label">Активных сегодня</div>
        <div class="stat-value">@Model.ActiveToday</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon warning"><i class="fas fa-user-plus"></i></div>
        <div class="stat-label">Новых за неделю</div>
        <div class="stat-value">@Model.NewThisWeek</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon danger"><i class="fas fa-wifi"></i></div>
        <div class="stat-label">Онлайн сейчас</div>
        <div class="stat-value">@Model.OnlineNow</div>
    </div>
</div>

<div class="content-grid cols-2 mb-6">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title"><i class="fas fa-history mr-2"></i>Последние действия</h3>
        </div>
        <div class="card-body" style="padding:0">
            <div class="table-responsive">
                <table class="table table-hover table-striped">
                    <thead>
                        <tr>
                            <th>Пользователь</th>
                            <th>Действие</th>
                            <th>Статус</th>
                            <th>Дата</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.RecentActivity)
                        {
                            <tr>
                                <td>@log.UserName</td>
                                <td>@log.Action</td>
                                <td>
                                    <span class="@(log.Status == "Success" ? "badge-success" : "badge-danger")">
                                        @log.Status
                                    </span>
                                </td>
                                <td class="text-muted text-sm">@log.CreatedAt.ToString("dd.MM HH:mm")</td>
                            </tr>
                        }
                        @if (!Model.RecentActivity.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted p-4">Нет записей</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3 class="card-title"><i class="fas fa-wifi mr-2"></i>Онлайн сейчас</h3>
            <span class="badge-success">@Model.OnlineUsers.Count</span>
        </div>
        <div class="card-body" style="padding:0">
            <div class="table-responsive">
                <table class="table table-hover table-striped">
                    <thead>
                        <tr>
                            <th>Пользователь</th>
                            <th>Email</th>
                            <th>IP</th>
                            <th>Последняя активность</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.OnlineUsers)
                        {
                            <tr>
                                <td>
                                    <i class="fas fa-circle text-success mr-2" style="font-size:0.5rem"></i>
                                    @user.UserName
                                </td>
                                <td class="text-muted">@user.Email</td>
                                <td class="text-muted text-sm">@(user.IpAddress ?? "—")</td>
                                <td class="text-muted text-sm">@user.LastActivity.ToString("dd.MM HH:mm:ss")</td>
                            </tr>
                        }
                        @if (!Model.OnlineUsers.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted p-4">Нет активных сессий</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
