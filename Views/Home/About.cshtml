@{
    ViewData["Title"] = "О системе";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-body p-4">
                <h2 class="text-center mb-4"><i class="bi bi-shield-lock"></i> JwtAuthDemo</h2>
                <p class="lead text-center">Система аутентификации и авторизации на основе JWT</p>

                <hr />

                <h5>Возможности:</h5>
                <ul class="list-group list-group-flush mb-4">
                    <li class="list-group-item"><i class="bi bi-check-circle text-success"></i> JWT-аутентификация с HttpOnly cookies</li>
                    <li class="list-group-item"><i class="bi bi-check-circle text-success"></i> RBAC + PBAC модель разрешений</li>
                    <li class="list-group-item"><i class="bi bi-check-circle text-success"></i> Управление пользователями и ролями</li>
                    <li class="list-group-item"><i class="bi bi-check-circle text-success"></i> Журнал аудита действий</li>
                    <li class="list-group-item"><i class="bi bi-check-circle text-success"></i> Dashboard со статистикой</li>
                    <li class="list-group-item"><i class="bi bi-check-circle text-success"></i> PostgreSQL + Entity Framework Core</li>
                </ul>

                <h5>Стек технологий:</h5>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-primary">ASP.NET Core 10</span>
                    <span class="badge bg-info">Entity Framework Core</span>
                    <span class="badge bg-success">PostgreSQL</span>
                    <span class="badge bg-warning">JWT Bearer</span>
                    <span class="badge bg-secondary">BCrypt</span>
                    <span class="badge bg-dark">Bootstrap 5</span>
                </div>
            </div>
        </div>
    </div>
</div>
