@{
    ViewData["Title"] = "О системе";
}

<div class="card">
    <div class="card-body">
        <h2 class="text-center"><i class="fas fa-shield-alt"></i> JwtAuthDemo</h2>
        <p class="text-center">Система аутентификации и авторизации на основе JWT</p>

        <hr />

        <h5>Возможности:</h5>
        <ul class="detail-list">
            <li><i class="fas fa-check-circle text-success"></i> JWT-аутентификация с HttpOnly cookies</li>
            <li><i class="fas fa-check-circle text-success"></i> RBAC + PBAC модель разрешений</li>
            <li><i class="fas fa-check-circle text-success"></i> Управление пользователями и ролями</li>
            <li><i class="fas fa-check-circle text-success"></i> Журнал аудита действий</li>
            <li><i class="fas fa-check-circle text-success"></i> Dashboard со статистикой</li>
            <li><i class="fas fa-check-circle text-success"></i> PostgreSQL + Entity Framework Core</li>
        </ul>

        <h5>Стек технологий:</h5>
        <div class="form-row">
            <span class="badge-success">ASP.NET Core 10</span>
            <span class="badge-gray">Entity Framework Core</span>
            <span class="badge-success">PostgreSQL</span>
            <span class="badge-gray">JWT Bearer</span>
            <span class="badge-gray">BCrypt</span>
            <span class="badge-gray">Custom CSS</span>
        </div>
    </div>
</div>
