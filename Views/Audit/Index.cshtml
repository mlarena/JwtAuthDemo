@model AuditLogViewModel
@{
    ViewData["Title"] = "Журнал аудита";
}

<div class="page-header">
    <h2><i class="fas fa-clipboard-list"></i> Журнал аудита</h2>
    <div class="page-actions">
        <span class="text-muted">Всего записей: @Model.TotalItems</span>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="form-row">
            <div class="form-group">
                <label class="form-label">Действие</label>
                <input type="text" name="action" value="@Model.FilterAction" class="form-control" placeholder="Действие" />
            </div>
            <div class="form-group">
                <label class="form-label">Статус</label>
                <select name="status" class="form-control">
                    <option value="">Все</option>
                    <option value="Success" selected="@(Model.FilterStatus == "Success")">Успех</option>
                    <option value="Failed" selected="@(Model.FilterStatus == "Failed")">Ошибка</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">С</label>
                <input type="date" name="from" value="@Model.FilterFrom?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="form-group">
                <label class="form-label">По</label>
                <input type="date" name="to" value="@Model.FilterTo?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="form-group">
                <button type="submit" class="btn btn-outline-primary">
                    <i class="fas fa-search"></i> Найти
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Пользователь</th>
                        <th>Действие</th>
                        <th>Ресурс</th>
                        <th>IP</th>
                        <th>Статус</th>
                        <th>Дата</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model.Logs)
                    {
                        <tr>
                            <td>@log.Id</td>
                            <td>@(log.UserName ?? "—")</td>
                            <td>@log.Action</td>
                            <td>@(log.Resource ?? "—")</td>
                            <td><small>@(log.IpAddress ?? "—")</small></td>
                            <td>
                                @if (log.Status == "Success")
                                {
                                    <span class="badge-success">@log.Status</span>
                                }
                                else
                                {
                                    <span class="badge-danger">@log.Status</span>
                                }
                            </td>
                            <td>@log.CreatedAt.ToString("dd.MM.yyyy HH:mm:ss")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <div class="pagination">
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <a class="btn @(i == Model.CurrentPage ? "btn-primary" : "btn-secondary") btn-sm"
               asp-action="Index"
               asp-route-page="@i"
               asp-route-action="@Model.FilterAction"
               asp-route-status="@Model.FilterStatus"
               asp-route-from="@Model.FilterFrom?.ToString("yyyy-MM-dd")"
               asp-route-to="@Model.FilterTo?.ToString("yyyy-MM-dd")">@i</a>
        }
    </div>
}
