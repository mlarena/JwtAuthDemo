<!DOCTYPE html>
<html lang="ru" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JwtAuthDemo</title>
    <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="admin-layout">
        <header class="admin-header">
            <div class="header-left">
                <button id="burgerBtn" class="burger-btn" aria-label="Меню">
                    <i class="fas fa-bars"></i>
                </button>
                <a class="header-brand" asp-controller="Home" asp-action="Dashboard">
                    <i class="fas fa-shield-halved"></i>
                    <span>JwtAuthDemo</span>
                </a>
            </div>
            <div class="header-right">
                <button id="themeToggle" class="theme-toggle" aria-label="Переключить тему">
                    <i class="fas fa-sun icon-sun"></i>
                    <i class="fas fa-moon icon-moon"></i>
                </button>
                <div class="header-divider"></div>
                <partial name="_LoginPartial" />
            </div>
        </header>

        <div id="sidebarOverlay" class="sidebar-overlay"></div>

        <aside id="sidebar" class="admin-sidebar">
            <nav class="sidebar-nav" role="navigation" aria-label="Главное меню">
                @{ var cc = ViewContext.RouteData.Values["Controller"]?.ToString(); }

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="sidebar-link @(cc == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")"
                       asp-controller="Home" asp-action="Dashboard">
                        <i class="fas fa-chart-pie icon"></i><span>Dashboard</span>
                    </a>

                    <div class="sidebar-group">
                        <div class="sidebar-group-title" data-group="management">
                            <i class="fas fa-cogs group-icon"></i><span>Управление</span>
                            <i class="fas fa-chevron-down group-arrow"></i>
                        </div>
                        <div class="sidebar-group-items" id="group-management">
                            @if (User.HasClaim(c => c.Type == "permission" && c.Value == "users:read"))
                            {
                                <a class="sidebar-link @(cc == "Users" ? "active" : "")" asp-controller="Users" asp-action="Index">
                                    <i class="fas fa-users icon"></i><span>Пользователи</span>
                                </a>
                            }
                            @if (User.HasClaim(c => c.Type == "permission" && c.Value == "roles:read"))
                            {
                                <a class="sidebar-link @(cc == "Roles" ? "active" : "")" asp-controller="Roles" asp-action="Index">
                                    <i class="fas fa-user-shield icon"></i><span>Роли</span>
                                </a>
                            }
                        </div>
                    </div>

                    <div class="sidebar-group">
                        <div class="sidebar-group-title" data-group="monitoring">
                            <i class="fas fa-chart-bar group-icon"></i><span>Мониторинг</span>
                            <i class="fas fa-chevron-down group-arrow"></i>
                        </div>
                        <div class="sidebar-group-items" id="group-monitoring">
                            @if (User.HasClaim(c => c.Type == "permission" && c.Value == "audit:read"))
                            {
                                <a class="sidebar-link @(cc == "Audit" ? "active" : "")" asp-controller="Audit" asp-action="Index">
                                    <i class="fas fa-history icon"></i><span>Аудит</span>
                                </a>
                            }
                        </div>
                    </div>

                    <div class="sidebar-footer">
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit" class="sidebar-link w-full">
                                <i class="fas fa-sign-out-alt icon"></i><span>Выход</span>
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <a class="sidebar-link @(cc == "Account" && ViewContext.RouteData.Values["Action"]?.ToString() == "Login" ? "active" : "")"
                       asp-controller="Account" asp-action="Login">
                        <i class="fas fa-sign-in-alt icon"></i><span>Вход</span>
                    </a>
                    <a class="sidebar-link @(cc == "Account" && ViewContext.RouteData.Values["Action"]?.ToString() == "Register" ? "active" : "")"
                       asp-controller="Account" asp-action="Register">
                        <i class="fas fa-user-plus icon"></i><span>Регистрация</span>
                    </a>
                }

                <a class="sidebar-link @(cc == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() == "About" ? "active" : "")"
                   asp-controller="Home" asp-action="About">
                    <i class="fas fa-info-circle icon"></i><span>О системе</span>
                </a>
            </nav>
        </aside>

        <main class="admin-main">
            <div class="content-wrapper">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle alert-icon"></i>
                        <div class="alert-content">@TempData["SuccessMessage"]</div>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-circle alert-icon"></i>
                        <div class="alert-content">@TempData["ErrorMessage"]</div>
                    </div>
                }
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js" asp-append-version="true"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.querySelectorAll('.password-toggle').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var input = this.closest('.input-group').querySelector('input');
                var icon = this.querySelector('i');
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.remove('fa-eye');
                    icon.classList.add('fa-eye-slash');
                } else {
                    input.type = 'password';
                    icon.classList.remove('fa-eye-slash');
                    icon.classList.add('fa-eye');
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
