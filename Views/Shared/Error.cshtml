@model ErrorViewModel
@{
    ViewData["Title"] = "Ошибка";
}

<div class="text-center mt-5">
    <h1 class="text-danger"><i class="bi bi-exclamation-triangle"></i> Ошибка</h1>
    <h2 class="text-danger">Произошла ошибка при обработке вашего запроса.</h2>
    @if (Model?.ShowRequestId == true)
    {
        <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
    }
</div>
